generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  studentId    String?  @unique @map("student_id")
  email        String   @unique
  fullName     String   @map("full_name")
  role         String   @default("student")
  faculty      String?
  year         Int?
  passwordHash String?  @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  registrations  Registration[]
  notifications  Notification[]

  @@map("users")
}

model Room {
  id          String  @id @default(uuid())
  name        String
  building    String?
  capacity    Int
  floorMapUrl String? @map("floor_map_url")

  workshops   Workshop[]

  @@map("rooms")
}

model Workshop {
  id              String    @id @default(uuid())
  title           String
  description     String?
  speakerName     String?   @map("speaker_name")
  speakerBio      String?   @map("speaker_bio")
  roomId          String?   @map("room_id")
  capacity        Int
  registeredCount Int       @default(0) @map("registered_count")
  startsAt        DateTime  @map("starts_at")
  endsAt          DateTime  @map("ends_at")
  price           Decimal   @default(0) @db.Decimal(10, 2)
  status          String    @default("draft")
  aiSummary       String?   @map("ai_summary")
  pdfUrl          String?   @map("pdf_url")
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  room          Room?          @relation(fields: [roomId], references: [id])
  registrations Registration[]

  @@map("workshops")
}

model Payment {
  id              String    @id @default(uuid())
  idempotencyKey  String    @unique @map("idempotency_key")
  amount          Decimal   @db.Decimal(10, 2)
  status          String    @default("pending")
  gatewayRef      String?   @map("gateway_ref")
  errorMessage    String?   @map("error_message")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  registration    Registration?

  @@map("payments")
}

model Registration {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  workshopId  String    @map("workshop_id")
  paymentId   String?   @unique @map("payment_id")
  status      String    @default("pending")
  qrCode      String?   @unique @map("qr_code")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User      @relation(fields: [userId], references: [id])
  workshop    Workshop  @relation(fields: [workshopId], references: [id])
  payment     Payment?  @relation(fields: [paymentId], references: [id])
  checkin     Checkin?

  @@unique([userId, workshopId])
  @@map("registrations")
}

model Checkin {
  id             String    @id @default(uuid())
  registrationId String    @unique @map("registration_id")
  checkedInAt    DateTime  @map("checked_in_at")
  syncedAt       DateTime? @map("synced_at")
  deviceId       String?   @map("device_id")
  isOffline      Boolean   @default(false) @map("is_offline")

  registration   Registration @relation(fields: [registrationId], references: [id])

  @@map("checkins")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  channel   String
  payload   Json
  status    String    @default("pending")
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model CsvImportLog {
  id           String    @id @default(uuid())
  filename     String?
  totalRows    Int?      @map("total_rows")
  importedRows Int?      @map("imported_rows")
  skippedRows  Int?      @map("skipped_rows")
  errorRows    Int?      @map("error_rows")
  errors       Json?
  status       String    @default("processing")
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")

  @@map("csv_import_logs")
}