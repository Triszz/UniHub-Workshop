п»ҝ[{"filePath":"D:\\UniHub\\UniHub-Workshop\\apps\\web\\src\\pages\\student\\WorkshopListPage.tsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nD:\\UniHub\\UniHub-Workshop\\apps\\web\\src\\pages\\student\\WorkshopListPage.tsx:78:10\n  76 |   // Initial fetch + refetch on filter change\n  77 |   useEffect(() => {\n> 78 |     void fetchWorkshops(true);\n     |          ^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  79 |   }, [fetchWorkshops]);\n  80 |\n  81 |   // Polling","line":78,"column":10,"nodeType":null,"endLine":78,"endColumn":24}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect, useCallback } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport { studentWorkshopService } from \"../../services/studentWorkshop.service\";\nimport type { Workshop } from \"../../types\";\n\n/* ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ helpers ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ */\n\nconst formatDate = (iso: string) =>\n  new Date(iso).toLocaleDateString(\"vi-VN\", {\n    weekday: \"short\",\n    day: \"2-digit\",\n    month: \"2-digit\",\n    year: \"numeric\",\n  });\n\nconst formatTime = (iso: string) =>\n  new Date(iso).toLocaleTimeString(\"vi-VN\", {\n    hour: \"2-digit\",\n    minute: \"2-digit\",\n  });\n\nconst formatPrice = (price: number) => {\n  if (price === 0) return \"MiГЎВ»вҖҰn phДӮВӯ\";\n  return new Intl.NumberFormat(\"vi-VN\", {\n    style: \"currency\",\n    currency: \"VND\",\n    maximumFractionDigits: 0,\n  }).format(price);\n};\n\nconst getSeatsInfo = (ws: Workshop) => {\n  const remaining = ws.capacity - ws.registeredCount;\n  const pct = ws.capacity > 0 ? (ws.registeredCount / ws.capacity) * 100 : 100;\n  return { remaining, pct };\n};\n\nconst isWorkshopPast = (ws: Workshop) => new Date(ws.endsAt) < new Date();\nconst isWorkshopOngoing = (ws: Workshop) => {\n  const now = new Date();\n  return new Date(ws.startsAt) <= now && now < new Date(ws.endsAt);\n};\n\n/* ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ component ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ */\n\nconst POLL_INTERVAL = 10_000; // 10 seconds\n\nexport const WorkshopListPage: React.FC = () => {\n  const [workshops, setWorkshops] = useState<Workshop[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState(\"\");\n  const [dateFilter, setDateFilter] = useState(\"\");\n\n  const fetchWorkshops = useCallback(\n    async (showLoader = true) => {\n      if (showLoader) setLoading(true);\n      setError(\"\");\n      try {\n        const params: Record<string, string | number> = { limit: 50 };\n        if (dateFilter) params.date = dateFilter;\n        const data = await studentWorkshopService.getAll(params);\n        setWorkshops(data.workshops);\n      } catch (err: unknown) {\n        const error = err as { response?: { data?: { error?: string; message?: string } } };\n        const msg =\n          error.response?.data?.error ||\n          error.response?.data?.message ||\n          \"KhДӮВҙng thГЎВ»Ж’ tГЎВәВЈi danh sДӮВЎch workshop\";\n        setError(msg);\n      } finally {\n        setLoading(false);\n      }\n    },\n    [dateFilter]\n  );\n\n  // Initial fetch + refetch on filter change\n  useEffect(() => {\n    void fetchWorkshops(true);\n  }, [fetchWorkshops]);\n\n  // Polling\n  useEffect(() => {\n    const interval = setInterval(() => {\n      void fetchWorkshops(false);\n    }, POLL_INTERVAL);\n    return () => clearInterval(interval);\n  }, [fetchWorkshops]);\n\n  const handleClearFilter = () => setDateFilter(\"\");\n\n  /* ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ render ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ */\n  return (\n    <>\n      {/* Header */}\n      <div className=\"mb-6\">\n        <h2 className=\"text-2xl font-bold text-gray-900\">\n          Danh sДӮВЎch Workshop\n        </h2>\n        <p className=\"mt-1 text-sm text-gray-500\">\n          KhДӮВЎm phДӮВЎ vДӮВ  Г„вҖҳГ„Ж’ng kДӮВҪ cДӮВЎc workshop sГЎВәВҜp diГЎВ»вҖҰn ra\n        </p>\n      </div>\n\n      {/* Filters */}\n      <div className=\"mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between\">\n        <div className=\"flex items-center gap-2\">\n          <label htmlFor=\"date-filter\" className=\"text-sm text-gray-600\">\n            LГЎВ»ВҚc theo ngДӮВ y:\n          </label>\n          <input\n            id=\"date-filter\"\n            type=\"date\"\n            value={dateFilter}\n            onChange={(e) => setDateFilter(e.target.value)}\n            className=\"rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-sm text-gray-700\n              shadow-sm transition-colors focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500\"\n          />\n          {dateFilter && (\n            <button\n              onClick={handleClearFilter}\n              className=\"rounded-lg px-2 py-1 text-xs text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors\"\n            >\n              ГўЕ“вҖў XДӮВіa lГЎВ»ВҚc\n            </button>\n          )}\n        </div>\n        <button\n          onClick={() => void fetchWorkshops(false)}\n          className=\"self-start rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-sm text-gray-600\n            shadow-sm transition-colors hover:bg-gray-50\"\n        >\n          ГўвҖ В» LДӮВ m mГЎВ»вҖәi\n        </button>\n      </div>\n\n      {/* Loading */}\n      {loading && (\n        <div className=\"flex items-center justify-center py-20\">\n          <div className=\"flex flex-col items-center gap-3\">\n            <div className=\"h-8 w-8 animate-spin rounded-full border-2 border-primary-200 border-t-primary-600\" />\n            <p className=\"text-sm text-gray-500\">Г„Вҗang tГЎВәВЈi danh sДӮВЎch...</p>\n          </div>\n        </div>\n      )}\n\n      {/* Error */}\n      {!loading && error && (\n        <div className=\"rounded-xl border border-red-200 bg-red-50 p-6 text-center\">\n          <p className=\"text-sm text-red-700\">{error}</p>\n          <button\n            onClick={() => void fetchWorkshops(true)}\n            className=\"mt-3 text-sm font-medium text-red-600 hover:underline\"\n          >\n            ThГЎВ»Вӯ lГЎВәВЎi\n          </button>\n        </div>\n      )}\n\n      {/* Empty */}\n      {!loading && !error && workshops.length === 0 && (\n        <div className=\"rounded-xl border border-dashed border-gray-300 bg-white p-12 text-center\">\n          <div className=\"mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-full bg-gray-100\">\n            <svg className=\"h-7 w-7 text-gray-400\" fill=\"none\" viewBox=\"0 0 24 24\" strokeWidth={1.5} stroke=\"currentColor\">\n              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342\" />\n            </svg>\n          </div>\n          <p className=\"text-sm font-medium text-gray-900\">\n            {dateFilter\n              ? \"KhДӮВҙng cДӮВі workshop nДӮВ o vДӮВ o ngДӮВ y nДӮВ y\"\n              : \"ChГҶВ°a cДӮВі workshop nДӮВ o Г„вҖҳГҶВ°ГЎВ»ВЈc cДӮВҙng bГЎВ»вҖҳ\"}\n          </p>\n          <p className=\"mt-1 text-xs text-gray-500\">\n            Vui lДӮВІng quay lГЎВәВЎi sau hoГЎВәВ·c thГЎВ»Вӯ lГЎВ»ВҚc theo ngДӮВ y khДӮВЎc\n          </p>\n        </div>\n      )}\n\n      {/* Workshop grid */}\n      {!loading && !error && workshops.length > 0 && (\n        <div className=\"grid gap-4 sm:grid-cols-2 lg:grid-cols-3\">\n          {workshops.map((ws) => {\n            const { remaining, pct } = getSeatsInfo(ws);\n            const past = isWorkshopPast(ws);\n            const ongoing = isWorkshopOngoing(ws);\n            const full = remaining <= 0;\n\n            return (\n              <Link\n                key={ws.id}\n                to={`/workshops/${ws.id}`}\n                className={`group relative flex flex-col rounded-xl border bg-white shadow-sm\n                  transition-all hover:shadow-md hover:-translate-y-0.5\n                  ${past ? \"opacity-60 border-gray-200\" : \"border-gray-200 hover:border-primary-200\"}`}\n              >\n                {/* Status badge */}\n                {ongoing && (\n                  <div className=\"absolute right-3 top-3 z-10\">\n                    <span className=\"inline-flex items-center gap-1 rounded-full bg-emerald-500 px-2 py-0.5 text-[10px] font-semibold text-white shadow-sm\">\n                      <span className=\"h-1.5 w-1.5 animate-pulse rounded-full bg-white\" />\n                      Г„Вҗang diГЎВ»вҖҰn ra\n                    </span>\n                  </div>\n                )}\n                {past && (\n                  <div className=\"absolute right-3 top-3 z-10\">\n                    <span className=\"rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-medium text-gray-500\">\n                      Г„ВҗДӮВЈ kГЎВәВҝt thДӮВәc\n                    </span>\n                  </div>\n                )}\n\n                {/* Content */}\n                <div className=\"flex flex-1 flex-col p-5\">\n                  {/* Price tag */}\n                  <div className=\"mb-3 flex items-center justify-between\">\n                    <span\n                      className={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${\n                        ws.price === 0\n                          ? \"bg-emerald-50 text-emerald-700\"\n                          : \"bg-amber-50 text-amber-700\"\n                      }`}\n                    >\n                      {formatPrice(ws.price)}\n                    </span>\n                  </div>\n\n                  {/* Title */}\n                  <h3 className=\"mb-2 text-base font-semibold text-gray-900 line-clamp-2 group-hover:text-primary-700 transition-colors\">\n                    {ws.title}\n                  </h3>\n\n                  {/* Speaker */}\n                  {ws.speakerName && (\n                    <p className=\"mb-3 flex items-center gap-1.5 text-sm text-gray-500\">\n                      <svg className=\"h-3.5 w-3.5 text-gray-400 shrink-0\" fill=\"none\" viewBox=\"0 0 24 24\" strokeWidth={1.5} stroke=\"currentColor\">\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z\" />\n                      </svg>\n                      <span className=\"truncate\">{ws.speakerName}</span>\n                    </p>\n                  )}\n\n                  {/* Meta */}\n                  <div className=\"mt-auto space-y-1.5 text-xs text-gray-500\">\n                    <div className=\"flex items-center gap-1.5\">\n                      <svg className=\"h-3.5 w-3.5 text-gray-400 shrink-0\" fill=\"none\" viewBox=\"0 0 24 24\" strokeWidth={1.5} stroke=\"currentColor\">\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5\" />\n                      </svg>\n                      <span>{formatDate(ws.startsAt)}</span>\n                      <span className=\"text-gray-300\">|</span>\n                      <span>{formatTime(ws.startsAt)} ГўвӮ¬вҖң {formatTime(ws.endsAt)}</span>\n                    </div>\n                    <div className=\"flex items-center gap-1.5\">\n                      <svg className=\"h-3.5 w-3.5 text-gray-400 shrink-0\" fill=\"none\" viewBox=\"0 0 24 24\" strokeWidth={1.5} stroke=\"currentColor\">\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z\" />\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z\" />\n                      </svg>\n                      <span>\n                        {ws.room?.name}\n                        {ws.room?.building && ` ГўвӮ¬вҖң ${ws.room.building}`}\n                      </span>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Seats bar */}\n                <div className=\"border-t border-gray-100 px-5 py-3\">\n                  <div className=\"flex items-center justify-between text-xs mb-1.5\">\n                    <span className=\"text-gray-500\">ChГЎВ»вҖ” cДӮВІn lГЎВәВЎi</span>\n                    <span\n                      className={`font-semibold ${\n                        full\n                          ? \"text-red-600\"\n                          : remaining <= 5\n                            ? \"text-amber-600\"\n                            : \"text-gray-700\"\n                      }`}\n                    >\n                      {full ? \"HГЎВәВҝt chГЎВ»вҖ”\" : `${remaining}/${ws.capacity}`}\n                    </span>\n                  </div>\n                  <div className=\"h-1.5 overflow-hidden rounded-full bg-gray-100\">\n                    <div\n                      className={`h-full rounded-full transition-all duration-500 ${\n                        pct >= 100\n                          ? \"bg-red-500\"\n                          : pct >= 80\n                            ? \"bg-amber-500\"\n                            : \"bg-primary-500\"\n                      }`}\n                      style={{ width: `${Math.min(pct, 100)}%` }}\n                    />\n                  </div>\n                </div>\n              </Link>\n            );\n          })}\n        </div>\n      )}\n\n      {/* Polling indicator */}\n      {!loading && !error && workshops.length > 0 && (\n        <p className=\"mt-6 text-center text-[11px] text-gray-400\">\n          DГЎВ»ВҜ liГЎВ»вҖЎu tГЎВ»Вұ Г„вҖҳГЎВ»в„ўng cГЎВәВӯp nhГЎВәВӯt mГЎВ»вҖ”i {POLL_INTERVAL / 1000} giДӮВўy\n        </p>\n      )}\n    </>\n  );\n};\n","usedDeprecatedRules":[]}]
